# 💻 Backend Configuration - EXAMPLE (Never commit .env with real secrets)

# ───────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ───────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION - PostgreSQL Local
# ───────────────────────────────────────────────────────────────
# For local PostgreSQL development
# DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/drugstoredb"

# ───────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION - Supabase (Production)
# ───────────────────────────────────────────────────────────────
# Uncomment for Supabase production database
# DATABASE_URL="postgresql://postgres.PROJECT_ID:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres"

# ───────────────────────────────────────────────────────────────
# AUTHENTICATION
# ───────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_à_changer_en_production
JWT_EXPIRATION=7d

# ───────────────────────────────────────────────────────────────
# CORS & SECURITY
# ───────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ───────────────────────────────────────────────────────────────
# LOGGING
# ───────────────────────────────────────────────────────────────
LOG_LEVEL=debug
